# webjs environment variables
# Copy to .env and fill in your values: cp .env.example .env
#
# Convention over configuration: set these and the framework auto-configures
# the right adapters. No webjs.config.js needed.

# ── Server ──────────────────────────────────────────────────────────
PORT=3000

# ── Sessions ────────────────────────────────────────────────────────
# Required for session support. Any random string, 32+ characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Redis (production scaling) ──────────────────────────────────────
# Set this and cache, sessions, rate limiting, pub/sub, and background
# jobs all automatically use Redis. Without it, everything uses
# in-memory/cookie defaults (great for development).
# REDIS_URL=redis://localhost:6379

# ── File storage (S3) ──────────────────────────────────────────────
# Set S3_BUCKET and file storage switches from local disk to S3.
# Works with AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces.
# Without it, files are stored locally in ./uploads/
# S3_BUCKET=my-app-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=                  # optional: for S3-compatible providers (MinIO, R2)

# ── Database ────────────────────────────────────────────────────────
# Used by Prisma. SQLite for dev (default in schema.prisma),
# PostgreSQL/MySQL for production.
# DATABASE_URL=postgresql://user:pass@localhost:5432/mydb
DATABASE_URL=file:./dev.db
