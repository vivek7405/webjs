# webjs blog example — environment variables
# Copy to .env: cp .env.example .env

# ── Server ──────────────────────────────────────────────────────────
PORT=3000

# ── Sessions ────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ── Redis (uncomment for production horizontal scaling) ─────────────
# REDIS_URL=redis://localhost:6379

# ── S3 (uncomment for cloud file storage) ───────────────────────────
# S3_BUCKET=my-blog-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
