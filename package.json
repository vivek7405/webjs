{
  "name": "webjs-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "webjs — an AI-first, no-build, web-components-first framework inspired by NextJs and Lit",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs",
    "website"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev --workspace=examples/blog",
    "test": "node --test test/*.test.js",
    "test:e2e": "WEBJS_E2E=1 node --test test/e2e.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "linkedom": "^0.18.12",
    "puppeteer-core": "^24.41.0"
  }
}
